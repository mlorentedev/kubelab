# Managed by Ansible — do not edit manually
# Source: infra/ansible/roles/headscale/templates/config.yaml.j2
# Headscale v0.28 configuration

server_url: https://{{ headscale_domain }}
listen_addr: 0.0.0.0:{{ headscale_listen_port }}

metrics_listen_addr: 127.0.0.1:9090

grpc_listen_addr: 127.0.0.1:50443
grpc_allow_insecure: false

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: {{ tailscale_cidr }}
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    enabled: {{ headscale_derp_enabled | lower }}
    region_id: {{ headscale_derp_region_id }}
    region_code: "{{ headscale_derp_region_code }}"
    region_name: "{{ headscale_derp_region_name }}"
    verify_clients: {{ headscale_derp_verify_clients | lower }}
    stun_listen_addr: "0.0.0.0:3478"
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
  urls:
    - https://controlplane.tailscale.com/derpmap/default
  paths: []
  auto_update_enabled: true
  update_frequency: 24h

dns:
  magic_dns: true
  base_domain: kubelab.vpn
  override_local_dns: true
  nameservers:
    global:
      - 1.1.1.1
      - 1.0.0.1
{% if headscale_dns_split %}
    split:
{% for domain, nameservers in headscale_dns_split.items() %}
      {{ domain }}:
{% for ns in nameservers %}
        - {{ ns }}
{% endfor %}
{% endfor %}
{% endif %}
  search_domains: []
{% if headscale_dns_extra_records %}
  extra_records:
{% for record in headscale_dns_extra_records %}
    - name: {{ record.name }}
      type: {{ record.type }}
      value: {{ record.value }}
{% endfor %}
{% endif %}

database:
  type: {{ headscale_db_type }}
  sqlite:
    path: /var/lib/headscale/db.sqlite
    write_ahead_log: true

ephemeral_node_inactivity_timeout: 30m
disable_check_updates: true

unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"

taildrop:
  enabled: true

log:
  level: info
  format: text

logtail:
  enabled: false

policy:
  mode: file
  path: ""
