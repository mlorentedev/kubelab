# {{ ansible_managed }}
# RPi3 Monitoring Services — Uptime Kuma. Glances extracted to the shared
# `roles/glances/` role (DASH-DT-014b) — invoked from provision-rpi3.yml.
services:
  uptime-kuma:
    image: {{ uptime_kuma_image }}
    container_name: uptime-kuma
    restart: {{ restart_policy }}
    ports:
      - "{{ uptime_kuma_port }}:3001"
    volumes:
      - uptime-kuma-data:/app/data
    healthcheck:
      test: ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3001', r => {process.exit(r.statusCode === 200 || r.statusCode === 302 ? 0 : 1)})\""]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

volumes:
  uptime-kuma-data:
    name: uptime-kuma_uptime_kuma_data
    external: true
