# Managed by Ansible — do not edit manually
# Headscale control plane — HTTP proxy (Traefik terminates TLS)
http:
  routers:
    headscale:
      rule: "Host(`{{ headscale_domain }}`)"
      entryPoints:
        - websecure
      service: headscale
      tls:
        certResolver: {{ traefik_cert_resolver }}

  services:
    headscale:
      loadBalancer:
        servers:
          - url: "http://headscale:{{ headscale_backend_port }}"
