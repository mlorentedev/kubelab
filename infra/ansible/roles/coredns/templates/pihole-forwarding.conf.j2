# Managed by Ansible — do not edit manually
# Pi-hole conditional forwarding to CoreDNS
# Uses Docker bridge gateway (not 127.0.0.1 — Pi-hole runs in Docker)
server=/{{ base_domain }}/172.17.0.1#{{ coredns_port }}
{% for zone in staging_zones %}
server=/{{ zone }}/172.17.0.1#{{ coredns_port }}
{% endfor %}
