#!/bin/bash
# {{ ansible_managed }}
# Node maintenance — runs via systemd timer
set -euo pipefail

echo "[$(date)] Starting maintenance on $(hostname)"

# APT cleanup
apt-get clean
rm -rf /var/lib/apt/lists/*
mkdir -p /var/lib/apt/lists/partial

# Journal vacuum
journalctl --vacuum-size={{ maintenance_journal_max_size }}

# Rotated rsyslog files older than N days (RELIAB-009 follow-up)
find /var/log -maxdepth 1 -type f \( \
    -name 'syslog.*' -o \
    -name '*.log.*' -o \
    -name 'btmp.*' -o \
    -name 'wtmp.*' -o \
    -name 'lastlog.*' \
\) -mtime +{{ maintenance_rotated_log_retention_days }} -delete 2>/dev/null || true

# Safety: truncate active syslog if it exceeds the max size
{% if maintenance_active_log_max_mb | int > 0 %}
find /var/log -maxdepth 1 -name syslog -size +{{ maintenance_active_log_max_mb }}M -exec truncate -s 0 {} \; 2>/dev/null || true
{% endif %}

# Snap cleanup
snap set system refresh.retain={{ maintenance_snap_retain }} 2>/dev/null || true
snap list --all 2>/dev/null | awk '/disabled/{system("snap remove " $1 " --revision=" $3)}' || true

# Docker cleanup (skip if not installed)
if command -v docker &>/dev/null; then
    docker image prune -af || echo "WARN: docker image prune failed"
    docker builder prune -af || echo "WARN: docker builder prune failed"
fi

# K3s cleanup (skip if not installed)
if command -v crictl &>/dev/null; then
    crictl rmi --prune || echo "WARN: crictl prune failed"
fi

# Temp files (skip symlinks to prevent traversal attacks)
find /tmp /var/tmp -type f -not -type l -atime +{{ maintenance_tmp_max_days }} -delete 2>/dev/null || true

echo "[$(date)] Maintenance complete:"
df -h /
