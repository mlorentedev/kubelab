# {{ ansible_managed }}
# Beelink Platform Services — MinIO + GitHub Actions Runner + Glances (ADR-028)
# This file contains rendered secrets — mode 0600, owned by root.
services:
  minio:
    image: {{ minio_image }}
    container_name: minio
    command: server /data --console-address ":{{ minio_console_port }}"
    restart: {{ restart_policy }}
    ports:
      - "{{ tailscale_ip }}:{{ minio_api_port }}:{{ minio_api_port }}"
      - "{{ tailscale_ip }}:{{ minio_console_port }}:{{ minio_console_port }}"
    environment:
      MINIO_ROOT_USER: "{{ minio_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ minio_root_password }}"
    volumes:
      - {{ beelink_minio_data_dir }}:/data
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ minio_api_port }}/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          cpus: "{{ minio_cpu_limit }}"
          memory: "{{ minio_memory_limit }}"
    networks:
      - kubelab

  github-runner:
    image: {{ runner_image }}
    container_name: github-runner
    restart: {{ restart_policy }}
    environment:
      REPO_URL: "{{ runner_repo_url }}"
      RUNNER_NAME: "kubelab-bee"
      ACCESS_TOKEN: "{{ runner_access_token }}"
      RUNNER_WORKDIR: /tmp/runner
      RUNNER_GROUP: "{{ runner_group }}"
      LABELS: "{{ runner_labels }}"
      EPHEMERAL: "1"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - runner_data:/tmp/runner
      - runner_toolcache:/opt/hostedtoolcache
    deploy:
      resources:
        limits:
          cpus: "{{ runner_cpu_limit }}"
          memory: "{{ runner_memory_limit }}"
    networks:
      - kubelab

  glances:
    image: {{ glances_image }}
    container_name: glances
    restart: {{ restart_policy }}
    ports:
      - "{{ tailscale_ip }}:{{ glances_port }}:{{ glances_port }}"
    environment:
      - GLANCES_OPT=-w
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /etc/os-release:/etc/os-release:ro
    deploy:
      resources:
        limits:
          cpus: "{{ glances_cpu_limit }}"
          memory: "{{ glances_memory_limit }}"
    pid: host

volumes:
  runner_data:
    name: github_runner_data
  runner_toolcache:
    name: github_runner_toolcache

networks:
  kubelab:
    name: kubelab
    external: true
