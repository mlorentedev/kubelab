# Managed by Ansible — do not edit manually
http:
  middlewares:
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true
{% if traefik_dashboard_auth_users %}
    auth:
      basicAuth:
        users:
          - '{{ traefik_dashboard_auth_users }}'
{% endif %}
    rate-limit:
      rateLimit:
        average: {{ traefik_rate_limit_average }}
        burst: {{ traefik_rate_limit_burst }}
        period: {{ traefik_rate_limit_period }}
    secure-headers:
      headers:
        frameDeny: true
        browserXssFilter: true
        contentTypeNosniff: true
        referrerPolicy: strict-origin-when-cross-origin
        contentSecurityPolicy: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://api.github.com https://api.cloudflare.com; frame-ancestors 'self'"
        permissionsPolicy: camera=(), microphone=(), geolocation=(), payment=()
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
