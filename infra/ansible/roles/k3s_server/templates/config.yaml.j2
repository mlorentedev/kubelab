{{ ansible_managed | comment }}
write-kubeconfig-mode: "{{ k3s_kubeconfig_mode }}"
{% if k3s_tls_san | length > 0 %}
tls-san:
{% for san in k3s_tls_san %}
  - "{{ san }}"
{% endfor %}
{% endif %}
{% if k3s_resolv_conf is defined and k3s_resolv_conf %}
resolv-conf: "{{ k3s_resolv_conf }}"
{% endif %}
{% if k3s_node_labels | length > 0 %}
node-label:
{% for label in k3s_node_labels %}
  - "{{ label }}"
{% endfor %}
{% endif %}
{% if k3s_terminated_pod_gc_threshold | int != 12500 %}
kube-controller-manager-arg:
  - "terminated-pod-gc-threshold={{ k3s_terminated_pod_gc_threshold }}"
{% endif %}
{% if k3s_etcd_snapshot_retention | int != 5 %}
etcd-snapshot-retention: {{ k3s_etcd_snapshot_retention }}
{% endif %}
