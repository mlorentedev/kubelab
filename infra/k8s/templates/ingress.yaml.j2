{% for app in apps %}
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ app.name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ app.name }}
    app.kubernetes.io/part-of: kubelab
    app.kubernetes.io/managed-by: toolkit
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ app.domain }}`)
      kind: Rule
      services:
        - name: {{ app.name }}
          port: {{ app.port }}
{% if app.middlewares %}
      middlewares:
{% for mw in app.middlewares %}
        - name: {{ mw }}
{% endfor %}
{% endif %}
  tls:
    certResolver: {{ cert_resolver }}
{% endfor %}
