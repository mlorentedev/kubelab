{# Homepage services.yaml — Generated from common.yaml SSOT.
   Run `make sync-homepage` to regenerate. Do NOT edit services.yaml directly. #}
{% set stg = "staging." + global.base_domain %}
{% set gp = 61208 %}
{% set n = nodes %}
{# ── DIAGRAMS (tables + SVGs, injected by custom.js) ── #}
- IP Reference:
    - placeholder:
        icon: mdi-table
- Topology:
    - placeholder:
        icon: mdi-map-marker-path
- DNS Map:
    - placeholder:
        icon: mdi-table
- DNS Resolution:
    - placeholder:
        icon: mdi-dns
- GitOps:
    - placeholder:
        icon: mdi-source-branch
- Request Path:
    - placeholder:
        icon: mdi-arrow-decision
- Secret Flow:
    - placeholder:
        icon: mdi-key-chain
- Deploy Pipeline:
    - placeholder:
        icon: mdi-rocket-launch
- Tech Stack:
    - placeholder:
        icon: mdi-tools
{# ── SERVICES (tables injected by custom.js) ── #}
- Shared:
    - placeholder:
        icon: mdi-share-variant
- Staging:
    - placeholder:
        icon: mdi-server
- Prod:
    - placeholder:
        icon: mdi-cloud
{# ── INFRA (widgets + hardware monitoring) ── #}
- Network:
    - Cloudflare:
        icon: si-cloudflare
        href: https://dash.cloudflare.com
        description: DNS analytics
        widget:
          type: customapi
          url: https://api.cloudflare.com/client/v4/graphql
          method: POST
          headers:
            Authorization: "Bearer {%raw%}{{HOMEPAGE_VAR_CLOUDFLARE_TOKEN}}{%endraw%}"
            Content-Type: application/json
          requestBody:
            # yamllint disable-line rule:line-length
            query: '{ viewer { zones(filter: {zoneTag: "{{ cloudflare_zone_id }}"}) { httpRequests1dGroups(limit: 1, filter: {date_gt: "{{ today }}"}) { sum { requests threats } } } } }'
          mappings:
            - field: data.viewer.zones.0.httpRequests1dGroups.0.sum.requests
              label: Requests
              format: number
            - field: data.viewer.zones.0.httpRequests1dGroups.0.sum.threats
              label: Threats
              format: number
    - Uptime Kuma:
        icon: si-uptimekuma
        href: https://{{ services.observability.uptime_kuma.domain }}
        description: RPi3 · Status
        widget:
          type: uptimekuma
          url: http://{{ n.rpi3.tailscale_ip }}:{{ services.observability.uptime_kuma.default_port }}
          slug: kubelab
    - Traefik Stg:
        icon: si-traefikproxy
        href: https://traefik.{{ stg }}/dashboard/
        description: Staging proxy
        widget:
          type: traefik
          url: http://{{ traefik_cluster_ip }}:9000
    - Traefik Prod:
        icon: si-traefikproxy
        href: https://{{ services.core.traefik.domain }}/dashboard/
        description: Prod proxy
        ping: https://{{ services.core.traefik.domain }}/dashboard/
    - CoreDNS (RPi4):
        icon: mdi-dns
        description: RPi4 · Staging DNS
        ping: http://{{ n.rpi4.tailscale_ip }}:8080
- Nodes:
{% for node_name, node in node_list %}
    - "{{ node_name }}":
        icon: {{ node.icon }}
        description: "{{ node.description }}"
{% if node.glances %}
        widget:
          type: glances
          url: http://{{ node.ip }}:{{ gp }}
{% if node.glances_version is defined %}
          version: {{ node.glances_version }}
{% else %}
          version: 4
{% endif %}
          metric: info
{% elif node.ping_url is defined %}
        ping: {{ node.ping_url }}
{% endif %}
{% endfor %}
