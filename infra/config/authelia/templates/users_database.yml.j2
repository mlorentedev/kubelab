# =============================================================================
# AUTHELIA USERS DATABASE
# =============================================================================
# Generated by toolkit. Do not edit manually.
# To add users:
#   1. Add user config to infra/config/values/common.yaml under apps.services.security.authelia.users
#   2. Run: toolkit credentials hash-password apps.authelia.users_{username}_password_hash --env {env}
#   3. Run: toolkit config generate --env {env}
#
users:
{% for user in authelia_users %}
  {{ user.username }}:
    disabled: {{ user.disabled | lower }}
    displayname: "{{ user.displayname }}"
    email: {{ user.email }}
    password: "{{ user.password_hash }}"
    groups:
{% for group in user.groups %}
      - {{ group }}
{% endfor %}
{% endfor %}
