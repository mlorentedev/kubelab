---
import '../styles/global.css';
import { site } from '../data/site';
import { languages } from '../i18n/ui';
import { getLocale, useTranslations, useTranslatedPath, switchLangUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const {
  title = site.title,
  description = t('meta.description'),
  ogImage = '/images/me-2.webp',
  ogType = 'website',
} = Astro.props;

const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url);
---

<!doctype html>
<html lang={lang} class="bg-slate-50 text-slate-700">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    {Object.keys(languages).map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(switchLangUrl(Astro.url, l as keyof typeof languages), site.url)} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url)} />

    <title>{pageTitle}</title>
  </head>
  <body class="font-roboto min-h-screen">
    <slot />
  </body>
</html>
