---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Not Found" description="Page not found.">
  <div class="text-center py-20">
    <h1 class="text-6xl font-bold text-slate-300 mb-4">404</h1>
    <p class="text-slate-500 text-lg mb-8">This page doesn't exist.</p>
    <a
      href="/"
      class="px-6 py-3 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-colors"
    >
      Go home
    </a>
  </div>
</PageLayout>
