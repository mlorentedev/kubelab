---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Not Found" description="This page doesn't exist.">
  <Header />
  <main id="main-content" class="flex-grow pt-12">
    <section class="pt-20 pb-16 md:pt-24 md:pb-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h1 class="text-6xl font-extrabold text-gray-300 mb-6">404</h1>
        <p class="text-gray-500 text-lg mb-10" data-en="This page doesn't exist." data-es="Esta página no existe."></p>
        <a
          id="home-link"
          href="/"
          class="inline-block px-6 py-3 bg-cyan-700 hover:bg-cyan-800 text-white font-medium rounded-md transition-colors text-sm"
          data-en="Go home"
          data-es="Ir al inicio"
        ></a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const isEs = window.location.pathname.startsWith('/es/') || window.location.pathname === '/es';
  const lang = isEs ? 'es' : 'en';

  document.querySelectorAll<HTMLElement>('[data-en][data-es]').forEach((el) => {
    el.textContent = el.dataset[lang] ?? '';
  });

  if (isEs) {
    const link = document.getElementById('home-link');
    if (link) link.setAttribute('href', '/es/');
    document.title = 'No encontrado | Manu Lorente';

    document.querySelectorAll<HTMLAnchorElement>('header a[href="/"]').forEach((a) => {
      a.href = '/es/';
    });
    document.querySelectorAll<HTMLAnchorElement>('header a[href="/notes"]').forEach((a) => {
      a.href = '/es/notes';
    });
    const langSwitcher = document.querySelector<HTMLAnchorElement>('header a[href*="switchLang"], header .uppercase');
    if (langSwitcher) {
      langSwitcher.textContent = 'English';
      langSwitcher.href = '/';
    }
  }
</script>
