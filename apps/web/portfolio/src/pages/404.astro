---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Not Found" description="Page not found.">
  <Header />
  <main>
    <section class="pt-28 pb-20 md:pt-36 md:pb-24">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h1 class="text-6xl font-heading font-bold text-slate-300 mb-6">404</h1>
        <p class="text-slate-500 text-lg mb-10">This page doesn't exist.</p>
        <a
          href="/"
          class="inline-block px-8 py-4 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-colors text-base"
        >
          Go home
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
