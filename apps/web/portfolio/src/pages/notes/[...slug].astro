---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft);
  return notes.map((note: CollectionEntry<'notes'>) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props as { note: CollectionEntry<'notes'> };
const { Content } = await render(note);

const formattedDate = note.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <Header />
  <main>
    <section class="pt-28 pb-20 md:pt-36 md:pb-24">
      <div class="max-w-3xl mx-auto px-6">
        <article>
          <header class="mb-10">
            <time class="text-sm text-slate-500">{formattedDate}</time>
            <h1 class="text-3xl font-heading font-bold text-slate-900 mt-3">{note.data.title}</h1>
            <div class="flex flex-wrap gap-2 mt-4">
              {note.data.tags.map((tag: string) => (
                <span class="px-2 py-0.5 text-xs rounded bg-slate-100 text-slate-500 border border-slate-200">
                  {tag}
                </span>
              ))}
            </div>
          </header>
          <div class="prose prose-lg max-w-none prose-slate prose-headings:font-heading prose-headings:font-bold prose-headings:text-slate-900 prose-p:text-slate-600 prose-li:text-slate-600 prose-strong:text-slate-800">
            <Content />
          </div>
        </article>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <a href="/notes" class="text-primary hover:text-primary-dark transition-colors">&larr; All notes</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
