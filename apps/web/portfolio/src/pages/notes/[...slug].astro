---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const notes = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft))
    .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

  return notes.map((note: CollectionEntry<'notes'>, i: number) => ({
    params: { slug: note.id },
    props: {
      note,
      prev: i > 0 ? { id: notes[i - 1].id, title: notes[i - 1].data.title } : null,
      next: i < notes.length - 1 ? { id: notes[i + 1].id, title: notes[i + 1].data.title } : null,
    },
  }));
}

const { note, prev, next } = Astro.props as {
  note: CollectionEntry<'notes'>;
  prev: { id: string; title: string } | null;
  next: { id: string; title: string } | null;
};
const { Content } = await render(note);

const formattedDate = note.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <Header />
  <main>
    <section class="pt-28 pb-20 md:pt-36 md:pb-24">
      <div class="max-w-3xl mx-auto px-6">
        <article>
          <header class="mb-10">
            <time class="text-sm text-slate-500">{formattedDate}</time>
            <h1 class="text-3xl font-heading font-bold text-slate-900 mt-3">{note.data.title}</h1>
            <div class="flex flex-wrap gap-2 mt-4">
              {note.data.tags.map((tag: string) => (
                <a href={`/tags/${tag.toLowerCase()}`} class="px-2 py-0.5 text-xs rounded bg-slate-100 text-slate-500 border border-slate-200 hover:bg-primary hover:text-white hover:border-primary transition-colors">
                  {tag}
                </a>
              ))}
            </div>
          </header>
          <div class="prose prose-lg max-w-none prose-slate prose-headings:font-heading prose-headings:font-bold prose-headings:text-slate-900 prose-p:text-slate-600 prose-li:text-slate-600 prose-strong:text-slate-800">
            <Content />
          </div>
        </article>
      </div>
    </section>

    <nav class="py-12 md:py-16 bg-white border-t border-slate-100">
      <div class="max-w-3xl mx-auto px-6">
        <div class="flex items-center justify-between gap-4">
          {prev ? (
            <a href={`/notes/${prev.id}`} class="group flex-1 min-w-0">
              <span class="text-xs text-slate-400">&larr; Previous</span>
              <span class="block text-sm font-heading font-bold text-slate-700 group-hover:text-primary transition-colors truncate mt-0.5">{prev.title}</span>
            </a>
          ) : <div class="flex-1" />}
          <a href="/notes" class="text-xs text-slate-400 hover:text-primary transition-colors shrink-0 px-2">All notes</a>
          {next ? (
            <a href={`/notes/${next.id}`} class="group flex-1 min-w-0 text-right">
              <span class="text-xs text-slate-400">Next &rarr;</span>
              <span class="block text-sm font-heading font-bold text-slate-700 group-hover:text-primary transition-colors truncate mt-0.5">{next.title}</span>
            </a>
          ) : <div class="flex-1" />}
        </div>
      </div>
    </nav>
  </main>
  <Footer />
</BaseLayout>
