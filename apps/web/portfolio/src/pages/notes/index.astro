---
import PageLayout from '../../layouts/PageLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft))
  .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title="Notes" description="Technical notes on platform engineering, infrastructure, and software.">
  <h1 class="text-3xl font-bold text-white mb-4">Notes</h1>
  <p class="text-gray-400 text-lg mb-8">
    Technical notes on platform engineering, Kubernetes, networking, and developer tooling.
  </p>

  {notes.length === 0 ? (
    <p class="text-gray-500">Coming soon.</p>
  ) : (
    <div class="grid md:grid-cols-2 gap-6">
      {notes.map((note: CollectionEntry<'notes'>) => (
        <NoteCard
          title={note.data.title}
          description={note.data.description}
          pubDate={note.data.pubDate}
          tags={note.data.tags}
          slug={note.id}
        />
      ))}
    </div>
  )}
</PageLayout>
