---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { projects } from '../../data/portfolio';

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft))
  .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = projects.filter((p) => p.featured);

const dateFormat: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
const formatDate = (d: Date) => d.toLocaleDateString('en-US', dateFormat);
---

<BaseLayout title="Notes" description="Platform engineering notes — from hardware to Kubernetes.">
  <Header />
  <main>
    <section class="pt-20 pb-20 md:pt-24 md:pb-28">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-lg text-slate-600 leading-relaxed max-w-2xl">
          <p class="mb-5">
            Most platform engineers learned Kubernetes from tutorials. I learned engineering
            from the metal up — hardware, firmware, backend, then cloud.
          </p>
          <p>
            That's why my platforms don't break.
          </p>
        </div>
        <a href="https://github.com/mlorentedev" target="_blank" rel="noopener noreferrer" class="block mt-10">
          <img
            src="https://ghchart.rshah.org/0e7490/mlorentedev"
            alt="Manu's GitHub contribution chart"
            class="w-full rounded"
            loading="lazy"
          />
        </a>

        <h2 class="text-sm text-slate-500 tracking-wide uppercase mt-16 mb-10">What I ship</h2>
        <div class="divide-y divide-slate-100">
          {featured.map((project) => (
            <div class="py-6 first:pt-0 last:pb-0">
              <h3 class="font-heading font-bold text-slate-900">
                {project.url ? (
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                    {project.title}
                  </a>
                ) : project.title}
              </h3>
              <p class="text-slate-600 text-sm mt-2 leading-relaxed">{project.description}</p>
              <div class="flex flex-wrap gap-1.5 mt-3">
                {project.tags.map((tag) => (
                  <a href={`/tags/${tag.toLowerCase()}`} class="px-2 py-0.5 text-xs rounded bg-slate-100 text-slate-500 hover:bg-primary hover:text-white transition-colors">
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-sm text-slate-500 tracking-wide uppercase mb-10">What I think</h2>
        {notes.length === 0 ? (
          <p class="text-slate-500">Coming soon.</p>
        ) : (
          <div class="divide-y divide-slate-100">
            {notes.map((note: CollectionEntry<'notes'>) => (
                <div class="py-6 first:pt-0 last:pb-0">
                  <a href={`/notes/${note.id}`} class="group block">
                    <time class="text-xs text-slate-400">{formatDate(note.data.pubDate)}</time>
                    <h3 class="font-heading font-bold text-slate-900 mt-1 group-hover:text-primary transition-colors">
                      {note.data.title}
                    </h3>
                    <p class="text-slate-600 text-sm mt-1.5 leading-relaxed">{note.data.description}</p>
                  </a>
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {note.data.tags.map((tag: string) => (
                      <a href={`/tags/${tag.toLowerCase()}`} class="px-2 py-0.5 text-xs rounded bg-slate-100 text-slate-500 hover:bg-primary hover:text-white transition-colors">
                        {tag}
                      </a>
                    ))}
                  </div>
                </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
