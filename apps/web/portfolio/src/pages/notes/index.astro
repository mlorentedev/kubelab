---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { projects } from '../../data/portfolio';

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft))
  .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = projects.filter((p) => p.featured);
---

<BaseLayout title="Notes" description="Platform engineering notes — from hardware to Kubernetes.">
  <Header />
  <main>
    <section class="pt-20 pb-10 md:pt-24 md:pb-14">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-lg text-slate-600 leading-relaxed max-w-2xl">
          <p class="mb-5">
            Most platform engineers learned Kubernetes from tutorials. I learned engineering
            from the metal up — hardware, firmware, backend, then cloud.
          </p>
          <p>
            That's why my platforms don't break.
          </p>
        </div>
        <a href="https://github.com/mlorentedev" target="_blank" rel="noopener noreferrer" class="block mt-10">
          <img
            src="https://ghchart.rshah.org/0e7490/mlorentedev"
            alt="Manu's GitHub contribution chart"
            class="w-full rounded"
            loading="lazy"
          />
        </a>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-sm text-slate-500 tracking-wide uppercase mb-10">Things I've built</h2>
        <div class="space-y-6">
          {featured.map((project) => (
            <div class="flex items-start gap-4">
              <div class="flex-1">
                <h3 class="font-heading font-bold text-slate-900">{project.title}</h3>
                <p class="text-slate-500 text-sm mt-1.5">{project.description}</p>
              </div>
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-slate-500 hover:text-primary transition-colors whitespace-nowrap"
                >
                  GitHub &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-sm text-slate-500 tracking-wide uppercase mb-10">Notes</h2>
        {notes.length === 0 ? (
          <p class="text-slate-500">Coming soon.</p>
        ) : (
          <div class="grid md:grid-cols-2 gap-6">
            {notes.map((note: CollectionEntry<'notes'>) => (
              <NoteCard
                title={note.data.title}
                description={note.data.description}
                pubDate={note.data.pubDate}
                tags={note.data.tags}
                slug={note.id}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
