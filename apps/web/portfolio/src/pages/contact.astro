---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Work with me" description="Work with me on your infrastructure challenges.">
  <Header />
  <main>
    <section class="pt-28 pb-20 md:pt-36 md:pb-24">
      <div class="max-w-3xl mx-auto px-6">
        <h1 class="text-3xl font-heading font-bold text-slate-900 mb-10">I don't do free discovery calls.</h1>

        <div class="space-y-5 text-lg text-slate-600 leading-relaxed max-w-2xl">
          <p>
            I take on 2–3 clients at a time. If I'm talking to you,
            I'm already working on your problem.
          </p>
          <p>
            Tell me what you're building, what's broken, and what you've tried.
            If I can help, I'll reply within 48 hours with a concrete proposal.
            If I can't, I'll tell you that too.
          </p>
          <p class="pt-4">
            <a
              href="mailto:info@mlorente.dev"
              class="inline-block px-8 py-4 bg-primary hover:bg-primary-dark focus:bg-primary-dark text-white font-medium rounded-lg transition-colors text-base outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              info@mlorente.dev
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
