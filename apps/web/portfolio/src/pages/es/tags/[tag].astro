---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import NoteCard from '../../../components/NoteCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { projects, type Project } from '../../../data/portfolio';
import { getLocale, useTranslations, useTranslatedPath } from '../../../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }: CollectionEntry<'notes'>) => !data.draft && data.lang === 'es');

  const tagSet = new Set<string>();
  for (const project of projects) {
    for (const tag of project.tags) tagSet.add(tag.toLowerCase());
  }
  for (const note of notes) {
    for (const tag of note.data.tags) tagSet.add(tag.toLowerCase());
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      matchingProjects: projects.filter((p) =>
        p.tags.some((t) => t.toLowerCase() === tag)
      ),
      matchingNotes: notes
        .filter((n: CollectionEntry<'notes'>) => n.data.tags.some((t: string) => t.toLowerCase() === tag))
        .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag: string;
  matchingProjects: Project[];
  matchingNotes: CollectionEntry<'notes'>[];
}

const { tag, matchingProjects, matchingNotes } = Astro.props;
const displayTag = matchingProjects.find((p) => p.tags.some((t) => t.toLowerCase() === tag))
  ?.tags.find((t) => t.toLowerCase() === tag)
  || matchingNotes[0]?.data.tags.find((t: string) => t.toLowerCase() === tag)
  || tag;
---

<BaseLayout title={`${displayTag}`} description={`${t('tags.projects')} & ${t('tags.notes')} — ${displayTag}.`}>
  <Header />
  <main id="main-content" class="flex-grow pt-12">
    <section class="pt-12 pb-6 md:pt-16 md:pb-10">
      <div class="max-w-3xl mx-auto px-4">
        <a href={translatePath('/notes')} class="text-sm text-gray-400 hover:text-cyan-700 transition-colors">&larr; {t('tags.all')}</a>
        <h1 class="text-2xl font-extrabold text-gray-800 mt-4">{displayTag}</h1>
      </div>
    </section>

    {matchingProjects.length > 0 && (
      <section class="py-12 md:py-16">
        <div class="max-w-3xl mx-auto px-4">
          <h2 class="text-sm text-gray-500 tracking-wide uppercase mb-8">{t('tags.projects')}</h2>
          <div class="divide-y divide-gray-200">
            {matchingProjects.map((project) => (
              <div class="py-5 first:pt-0 last:pb-0">
                <h3 class="font-bold text-gray-800">
                  {project.url ? (
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:text-cyan-700 transition-colors">
                      {project.title}
                    </a>
                  ) : project.title}
                </h3>
                <p class="text-gray-600 text-sm mt-1.5 leading-relaxed">{project.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {matchingNotes.length > 0 && (
      <section class="py-12 md:py-16">
        <div class="max-w-3xl mx-auto px-4">
          <h2 class="text-sm text-gray-500 tracking-wide uppercase mb-8">{t('tags.notes')}</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {matchingNotes.map((note) => (
              <NoteCard
                title={note.data.title}
                description={note.data.description}
                pubDate={note.data.pubDate}
                tags={note.data.tags}
                slug={note.id}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>
