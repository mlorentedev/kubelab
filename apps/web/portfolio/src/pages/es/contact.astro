---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getLocale, useTranslations } from '../../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
---

<BaseLayout title={t('contact.title')} description={t('contact.description')}>
  <Header />
  <main>
    <section class="pt-28 pb-20 md:pt-36 md:pb-24">
      <div class="max-w-3xl mx-auto px-6">
        <h1 class="text-3xl font-heading font-bold text-slate-900 mb-10">{t('contact.heading')}</h1>

        <div class="space-y-5 text-lg text-slate-600 leading-relaxed max-w-2xl">
          <p>{t('contact.p1')}</p>
          <p>{t('contact.p2')}</p>
          <p class="pt-4">
            <a
              href="mailto:info@mlorente.dev"
              class="inline-block px-8 py-4 bg-primary hover:bg-primary-dark focus:bg-primary-dark text-white font-medium rounded-lg transition-colors text-base outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              info@mlorente.dev
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
