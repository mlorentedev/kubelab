---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import { useTranslations, useTranslatedPath, getLocale } from '../../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout>
  <Header />
  <main id="main-content" class="flex-grow pt-12">
    <Hero />

    <section id="lead-magnet" class="py-12">
      <div class="max-w-3xl mx-auto px-4">
        <div class="flex flex-col max-w-3xl mx-auto space-y-4 mb-6">
          <p class="text-base text-gray-700">{t('leadMagnet.pitch1')}</p>
          <p class="text-base text-gray-700">{t('leadMagnet.pitch2')}</p>
          <p class="text-base text-gray-700">{t('leadMagnet.pitch3')}</p>
        </div>

        <SubscribeForm
          formId="nodo-home"
          tag="nodo"
          buttonText={t('leadMagnet.button')}
          placeholder={t('leadMagnet.placeholder')}
          successText={t('leadMagnet.success')}
          errorText={t('leadMagnet.error')}
        />

        <p class="text-sm text-gray-600 mt-6">{t('leadMagnet.courseDesc')}</p>
        <p class="text-sm text-gray-600 mt-2">{t('leadMagnet.microNote')}</p>
      </div>
    </section>

    <section class="py-12">
      <div class="max-w-3xl mx-auto px-4">
        <p class="text-sm text-gray-500">
          ¿Qué notas? <a href={translatePath('/notes')} class="text-cyan-700 hover:text-cyan-800 transition-colors">estas</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
