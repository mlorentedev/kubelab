---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import { useTranslations, useTranslatedPath, getLocale } from '../../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout>
  <Header />
  <main id="main-content" class="flex-grow pt-12">
    <Hero />

    <section id="lead-magnet" class="py-12">
      <div class="max-w-3xl mx-auto px-4">
        <div class="flex flex-col max-w-3xl mx-auto space-y-4 mb-6">
          <p class="text-base text-gray-700">{t('leadMagnet.pitch1')}</p>
          <p class="text-base text-gray-700">{t('leadMagnet.pitch2')}</p>
          <p class="text-base text-gray-700">{t('leadMagnet.pitch3')}</p>
        </div>

        <div class="bg-cyan-700 text-white p-4 rounded-md max-w-xs mx-auto">
          <form id="lead-magnet-form" class="flex flex-col gap-4" novalidate>
            <input type="email" name="email" required autocomplete="email" placeholder={t('leadMagnet.placeholder')} class="w-full p-2 text-cyan-700 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-cyan-300" aria-label="Email" />
            <button type="submit" class="w-full px-4 py-1.5 bg-white text-cyan-700 rounded-md text-sm font-medium hover:bg-cyan-100 transition-colors focus:outline-none focus:ring-2 focus:ring-white">{t('leadMagnet.button')}</button>
            <p id="lead-magnet-msg" class="text-xs text-center hidden"></p>
          </form>
        </div>

        <p class="text-sm text-gray-600 mt-6">{t('leadMagnet.courseDesc')}</p>
        <p class="text-sm text-gray-600 mt-2">{t('leadMagnet.microNote')}</p>
      </div>
    </section>

    <section class="py-12">
      <div class="max-w-3xl mx-auto px-4">
        <p class="text-sm text-gray-500">
          ÂżQuĂ© notas? <a href={translatePath('/notes')} class="text-cyan-700 hover:text-cyan-800 transition-colors">estas</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('lead-magnet-form') as HTMLFormElement | null;
  const msg = document.getElementById('lead-magnet-msg');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email') as string;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (msg) {
        msg.textContent = 'Por favor, introduce un email vĂˇlido.';
        msg.className = 'text-xs text-center text-red-200';
      }
      return;
    }
    // TODO: wire to API Go /api/subscribe with NODO tag
    if (msg) {
      msg.textContent = 'PrĂłximamente. ApĂşntalo y te aviso.';
      msg.className = 'text-xs text-center text-cyan-200';
    }
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (button) {
      button.disabled = true;
      button.textContent = 'Recibido';
    }
  });
</script>
