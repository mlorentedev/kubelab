---
import { skillGroups } from '../data/skills';
---

<section class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-2xl font-bold text-slate-900 mb-8">Skills</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {skillGroups.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">
            {group.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="px-3 py-1.5 text-sm rounded-lg bg-white text-slate-600 border border-slate-200">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
