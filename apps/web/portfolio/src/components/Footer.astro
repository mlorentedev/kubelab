---
import { getLocale, useTranslations } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-100">
  <div class="max-w-3xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-500">
    <a
      href="https://kubelab.live"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-primary focus:text-primary transition-colors outline-none"
    >
      {t('footer.blog')} &rarr;
    </a>
    <span>&copy; {year} Manu Lorente</span>
  </div>
</footer>
