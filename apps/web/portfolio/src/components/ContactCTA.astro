---
import { getLocale, useTranslations } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);

const steps = [
  { title: t('cta.step1.title'), desc: t('cta.step1.desc') },
  { title: t('cta.step2.title'), desc: t('cta.step2.desc') },
  { title: t('cta.step3.title'), desc: t('cta.step3.desc') },
  { title: t('cta.step4.title'), desc: t('cta.step4.desc') },
  { title: t('cta.step5.title'), desc: t('cta.step5.desc') },
];
---

<section class="py-20 md:py-28 bg-slate-50">
  <div class="max-w-3xl mx-auto px-6">

    <h2 class="text-sm text-slate-500 tracking-wide uppercase mb-14">{t('cta.heading')}</h2>
    <div class="space-y-6 text-slate-600 mb-20">
      {steps.map((step, i) => (
        <div class="flex items-start gap-4">
          <span class="text-primary font-heading font-bold text-lg mt-0.5">{String(i + 1).padStart(2, '0')}</span>
          <p><strong class="text-slate-900">{step.title}</strong> — {step.desc}</p>
        </div>
      ))}
    </div>

    <div class="bg-white rounded-lg p-10 mb-20 border border-slate-200">
      <h3 class="text-lg font-heading font-bold text-slate-900 mb-4">{t('cta.guarantee.title')}</h3>
      <p class="text-slate-600 leading-relaxed">
        {t('cta.guarantee.text')}
      </p>
    </div>

    <h2 class="text-2xl font-heading font-bold text-slate-900 mb-5">{t('cta.final.title')}</h2>
    <p class="text-slate-600 mb-10 max-w-xl">
      {t('cta.final.text')}
    </p>
    <a
      href="mailto:info@mlorente.dev"
      class="inline-block px-8 py-4 bg-primary hover:bg-primary-dark focus:bg-primary-dark text-white font-medium rounded-lg transition-colors text-base outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
    >
      info@mlorente.dev
    </a>
  </div>
</section>
