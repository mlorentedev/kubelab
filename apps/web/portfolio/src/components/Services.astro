---
import { getServices } from '../data/services';
import { getLocale, useTranslations } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const services = getServices(lang);
---

<section class="py-20 md:py-28 bg-white">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-sm text-slate-500 tracking-wide uppercase mb-14">{t('services.heading')}</h2>
    <div class="space-y-16">
      {services.map((service) => (
        <div>
          <h3 class="text-xl font-heading font-bold text-slate-900 mb-4">{service.headline}</h3>
          <p class="text-slate-500 mb-4">{service.problem}</p>
          <p class="text-slate-600 leading-relaxed">{service.solution}</p>
        </div>
      ))}
    </div>
  </div>
</section>
