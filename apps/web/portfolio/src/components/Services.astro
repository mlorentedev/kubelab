---
import { services } from '../data/services';
---

<section class="py-16 md:py-20">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-sm text-slate-400 tracking-wide uppercase mb-12">How I can help</h2>
    <div class="space-y-14">
      {services.map((service) => (
        <div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">{service.headline}</h3>
          <p class="text-slate-400 mb-2">{service.problem}</p>
          <p class="text-slate-600 leading-relaxed">{service.solution}</p>
        </div>
      ))}
    </div>
  </div>
</section>
