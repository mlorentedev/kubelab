---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Notes', href: '/notes' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-slate-100">
  <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="text-lg font-semibold text-slate-900 hover:text-primary transition-colors">
      Manu Lorente
    </a>
    <ul class="flex gap-8 text-sm">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'hover:text-primary transition-colors',
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-primary font-medium'
                : 'text-slate-400',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
