---
import { languages } from '../i18n/ui';
import { getLocale, useTranslations, useTranslatedPath, switchLangUrl } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navItems: { label: string; href: string }[] = [];

const currentPath = Astro.url.pathname;
const otherLangs = Object.entries(languages).filter(([l]) => l !== lang);
---

<header class="bg-cyan-50 text-gray-700 fixed w-full border-b border-cyan-100 z-50">
  <nav class="max-w-3xl mx-auto px-4 py-2 flex items-center justify-between">
    <h2 class="text-lg font-extrabold">
      <a href={translatePath('/')} class="no-underline hover:text-cyan-700 transition-colors duration-200 focus:outline-none focus:text-cyan-700">
        Manu Lorente
      </a>
    </h2>

    <div class="hidden md:flex items-center space-x-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'hover:text-cyan-700 focus:outline-none focus:text-cyan-700 transition-colors duration-200 text-sm',
            currentPath === item.href || currentPath.startsWith(item.href + '/')
              ? 'text-cyan-700 font-bold no-underline'
              : '',
          ]}
        >
          {item.label}
        </a>
      ))}
      {otherLangs.map(([l, label]) => (
        <a
          href={switchLangUrl(Astro.url, l as keyof typeof languages)}
          class="text-xs text-gray-400 hover:text-cyan-700 focus:outline-none focus:text-cyan-700 transition-colors uppercase tracking-wide"
        >
          {label}
        </a>
      ))}
    </div>

    <button
      id="menu-toggle"
      class="md:hidden text-gray-500 hover:text-cyan-700 transition-colors outline-none"
      aria-label={t('nav.toggle')}
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-cyan-100">
    <ul class="max-w-3xl mx-auto px-4 py-4 space-y-3 text-sm">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-1 hover:text-cyan-700 transition-colors',
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-cyan-700 font-bold'
                : '',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      {otherLangs.map(([l, label]) => (
        <li>
          <a
            href={switchLangUrl(Astro.url, l as keyof typeof languages)}
            class="block py-1 text-gray-400 hover:text-cyan-700 transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function closeMenu() {
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
    }
  });
</script>
