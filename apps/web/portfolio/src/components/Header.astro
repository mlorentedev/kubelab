---
import { languages } from '../i18n/ui';
import { getLocale, useTranslations, useTranslatedPath, switchLangUrl } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navItems = [
  { label: t('nav.notes'), href: translatePath('/notes') },
  { label: t('nav.contact'), href: translatePath('/contact') },
];

const currentPath = Astro.url.pathname;
const otherLangs = Object.entries(languages).filter(([l]) => l !== lang);
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-slate-100">
  <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href={translatePath('/')} class="text-lg font-heading font-bold text-slate-900 hover:text-primary focus:text-primary transition-colors outline-none">
      Manu Lorente
    </a>

    <div class="hidden md:flex items-center gap-8">
      <ul class="flex gap-8 text-sm">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'hover:text-primary focus:text-primary transition-colors outline-none',
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-primary font-medium'
                  : 'text-slate-500',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      {otherLangs.map(([l, label]) => (
        <a
          href={switchLangUrl(Astro.url, l as keyof typeof languages)}
          class="text-xs text-slate-400 hover:text-primary transition-colors uppercase tracking-wide"
        >
          {label}
        </a>
      ))}
    </div>

    <button
      id="menu-toggle"
      class="md:hidden text-slate-500 hover:text-primary focus:text-primary transition-colors outline-none"
      aria-label={t('nav.toggle')}
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100">
    <ul class="max-w-3xl mx-auto px-6 py-4 space-y-3 text-sm">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-1 hover:text-primary transition-colors',
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-primary font-medium'
                : 'text-slate-500',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      {otherLangs.map(([l, label]) => (
        <li>
          <a
            href={switchLangUrl(Astro.url, l as keyof typeof languages)}
            class="block py-1 text-slate-400 hover:text-primary transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
