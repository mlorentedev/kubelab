---
import { getLocale, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const isEs = lang === 'es';
const ctaHref = isEs ? '#newsletter' : translatePath('/notes');
---

<section class="pt-20 pb-16 md:pt-24 md:pb-20">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <h1 class="text-5xl md:text-6xl font-extrabold text-gray-800">
      {t('hero.title')}
    </h1>
    <p class="text-base text-gray-700 max-w-2xl mx-auto mt-6">
      {t('hero.subtitle')}
    </p>
    <div class="mt-8">
      <a
        href={ctaHref}
        class="inline-block px-6 py-3 bg-cyan-700 hover:bg-cyan-800 text-white font-medium rounded-md transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-cyan-700 focus:ring-offset-2"
      >
        {t('hero.cta')}
      </a>
    </div>
  </div>
</section>
