---
import { getLocale, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section class="pt-28 pb-20 md:pt-36 md:pb-24">
  <div class="max-w-3xl mx-auto px-6">
    <p class="text-sm text-primary font-medium tracking-wide mb-8">
      {t('hero.tagline')}
    </p>
    <h1 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 leading-tight mb-10">
      {t('hero.title')}
    </h1>
    <p class="text-xl text-slate-600 leading-relaxed max-w-2xl mb-5">
      {t('hero.subtitle1')}
    </p>
    <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mb-12">
      {t('hero.subtitle2')}
    </p>
    <a
      href={translatePath('/contact')}
      class="inline-block px-8 py-4 bg-primary hover:bg-primary-dark focus:bg-primary-dark text-white font-medium rounded-lg transition-colors text-base outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
    >
      {t('hero.cta')}
    </a>
  </div>
</section>
