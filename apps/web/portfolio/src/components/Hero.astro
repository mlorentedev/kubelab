---
import { getLocale, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const isEs = lang === 'es';
---

<section class="pt-12 pb-6 md:pt-16 md:pb-8">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-6xl font-extrabold text-gray-800">
      {t('hero.title')}
    </h1>
    <p class="text-base text-gray-700 max-w-2xl mx-auto mt-6">
      {t('hero.subtitle')}
    </p>
  </div>
</section>
