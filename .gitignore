# Environment files — ignore real values, keep examples
.env
.env.local
.env.dev
.env.staging
.env.prod
.env.*
!.env.example
!.env.*.example
infra/config/env/.env.*
!infra/config/env/.env.*.example

# Secrets & Certificates (includes Authelia JWKS keys)
certbot/
certs/
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs
logs/
*.log

# AI assistants
.claude/
.chat/
# AGENTS.md is the committed cross-agent SSOT (like web/iris/mail2markdown) — NOT ignored.
GEMINI.md
MEMORY.md

# Uptime Kuma backups (binary SQLite, use `toolkit monitoring backup` to pull)
infra/config/uptime-kuma/*.db

# Docker overrides
docker-compose.override.yml

# Docker-created artifacts (volume mount directories)
# Prevent accidental directory creation by Docker when volume sources don't exist
apps/**/.env.*/
apps/**/loki/
apps/**/vector.toml/
apps/**/nginx.conf/

# Wiki build output
apps/wiki/generated_docs

# K8s overlay generated manifests — committed for GitOps (ArgoCD reads from Git).
# Regenerate with: make deploy-k8s ENV=<env> (or toolkit infra k8s deploy --env <env>)
# Previously gitignored, unignored for ARGO-007.

# Rendered Traefik Middlewares (contain plaintext API keys post-render).
# Source templates: infra/k8s/overlays/*/middlewares/*.tpl  (committed).
# Rendered output: infra/k8s/overlays/*/middlewares/.rendered/*.yaml  (gitignored, audit copy).
# Re-render: `make apply-middleware-secrets ENV=<env>` (toolkit/features/k8s_middlewares.py).
infra/k8s/overlays/*/middlewares/.rendered/

# Ansible runtime cache (collections/modules/roles installed locally)
.ansible/

# Security scanning
.cache_ggshield
.aider*

# Git worktrees (parallel workspaces)
.worktrees/
